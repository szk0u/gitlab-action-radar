{
  "name": "gitlab-action-radar",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "bun run fmt:check && bun run lint && bun run test && bun run build",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix --deny-warnings",
    "preview": "vite preview",
    "prepare": "lefthook install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "tauri": "tauri",
    "test": "vitest run",
    "test:visual": "bun run build-storybook && playwright test",
    "test:visual:update": "bun run build-storybook && playwright test --update-snapshots",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/instrument-sans": "^5.2.8",
    "@tauri-apps/api": "latest",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-store": "^2.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-preact": "^1.8.0",
    "preact": "latest",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@preact/preset-vite": "latest",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/preact-vite": "10.3.5",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "latest",
    "@types/node": "latest",
    "http-server": "^14.1.1",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "storybook": "10.3.5",
    "tailwindcss": "^4.2.4",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "packageManager": "bun@1.3.14"
}
